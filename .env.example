# Template for local configuration. Copy to .env and fill in real values:
#   cp .env.example .env
# .env is gitignored — your real keys never leave your machine.

# Ethereum mainnet RPC HTTPS endpoint. Used by:
#   - cmd/probe-uniswap   (Step 2: eth_call against Uniswap V3 QuoterV2)
#   - the production daemon (when Step 4 lands)
# Get a free key at https://www.alchemy.com — create an app on Ethereum Mainnet
# and copy the HTTPS URL from the app's "Endpoints" tab.
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Ethereum mainnet RPC WebSocket endpoint. Used by:
#   - cmd/probe-chain     (Step 3: newHeads subscription)
#   - the production daemon (when Step 4 lands)
# Same Alchemy app — copy the WSS URL from "Endpoints".
ETH_RPC_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
