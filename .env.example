# Template for local configuration. Copy to .env and fill in real values:
#   cp .env.example .env
# .env is gitignored — your real keys never leave your machine.

# Ethereum mainnet RPC HTTPS endpoint. Used for every on-chain
# eth_call — today only QuoterV2 (Uniswap V3), but any future on-chain
# reader (other DEX, gas oracle, etc.) would reuse this URL. Get a
# free key at https://www.alchemy.com — create an app on Ethereum
# Mainnet and copy the HTTPS URL from the app's "Endpoints" tab.
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Ethereum mainnet RPC WebSocket endpoint. Used by the arbd block
# subscriber and cmd/probe-chain for newHeads. Same Alchemy app — copy
# the WSS URL from "Endpoints" (shares the key with the HTTPS endpoint).
ETH_RPC_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Slog level for arbd's internal logs (subscriber/dispatcher/pathfinder
# events, retry warnings, breaker state changes). Accepts DEBUG / INFO /
# WARN / ERROR, case-insensitive. Empty = INFO. The arbitrage-alert
# event itself is emitted independently and is NOT gated by this.
LOG_LEVEL=INFO

# Local-dev / terminal mode. When true, arbd writes the multi-line
# human-readable opportunity block to stdout alongside the structured
# slog event, AND structured logs use slog's TextHandler (key=value
# lines, terminal-friendly). When false, the pretty block is
# suppressed and structured logs use the JSONHandler (one JSON object
# per line, log-aggregator-friendly). Off in production.
# Accepts true/false/1/0.
PRETTY_ALERTS=true

# Where Binance lives. Switch to https://api.binance.us for US-region
# accounts, or a testnet base URL when developing.
BINANCE_BASE_URL=https://api.binance.com

# Which Uniswap V3 pool to query. The fee tier identifies the pool for
# the configured ETH-USDC pair: 500=0.05%, 3000=0.3%, 10000=1%.
UNISWAP_POOL_FEE=3000

# QuoterV2 contract address. Mainnet canonical deployment is
# 0x61fFE014bA17989E743c5F6cB21bF9697530B21e — change only when
# targeting a non-mainnet network or a future Quoter deployment.
UNISWAP_QUOTER_ADDRESS=0x61fFE014bA17989E743c5F6cB21bF9697530B21e
