# Template for local configuration. Copy to .env and fill in real values:
#   cp .env.example .env
# .env is gitignored — your real keys never leave your machine.

# Ethereum mainnet RPC HTTPS endpoint. Used by cmd/probe-uniswap for
# eth_call against Uniswap V3's QuoterV2.
# Get a free key at https://www.alchemy.com — create an app on Ethereum
# Mainnet and copy the HTTPS URL from the app's "Endpoints" tab.
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Ethereum mainnet RPC WebSocket endpoint. Used by cmd/probe-chain for the
# newHeads subscription. Same Alchemy app — copy the WSS URL from
# "Endpoints" (it shares the key with the HTTPS endpoint above).
ETH_RPC_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Slog level for arbd's internal logs (subscriber/dispatcher/pathfinder
# events, retry warnings, breaker state changes). Accepts DEBUG / INFO /
# WARN / ERROR, case-insensitive. Empty = INFO. The arbitrage-alert
# event itself is emitted independently and is NOT gated by this.
LOG_LEVEL=INFO

# When true, arbd also writes the multi-line human-readable opportunity
# block to stdout alongside the structured slog event — useful for
# local-dev terminals, off in production. Accepts true/false/1/0.
PRETTY_ALERTS=true
